{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(git init)",
      "Bash(git switch:*)",
      "Bash(git stash *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read fp; [[ \"$fp\" =~ \\.tsx?$ ]] && npx prettier --write \"$fp\"; }"
          }
        ]
      }
    ]
  }
}
